DATABASE_URL=postgresql+psycopg://openar:openar_dev@localhost:5532/openar
JWT_SECRET_KEY=local-dev-jwt-secret-do-not-use-in-production
BETTER_AUTH_BASE_URL=http://localhost:3001
BETTER_AUTH_BASE_PATH=/api/auth

# CORS_ALLOW_PRIVATE_NETWORK_ORIGINS=false
# STREAM_WARM_LEASE_SECONDS=30

# MediaMTX auth bridge
# MEDIAMTX_ALLOW_LOCAL_PUBLISH_WITHOUT_CREDENTIALS=false
# MEDIAMTX_ALLOW_LOCAL_READ_WITHOUT_TOKEN=true
# MEDIAMTX_PUBLIC_READ_STREAM_IDS=fusion
# MEDIAMTX_PUBLISH_USER=
# MEDIAMTX_PUBLISH_PASS=

# CV detector device: cuda, mps (Mac Metal), cpu, or empty for auto (CUDA > MPS > CPU)
# DETECTOR_DEVICE=mps

# FFmpeg codec: h264_videotoolbox (Mac), h264_nvenc (NVIDIA), libx264 (CPU), auto
# FFMPEG_CODEC=auto
# FFPROBE_BIN=ffprobe

# S3
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/bridgable/openar/
# S3_PRESIGN_EXPIRES=900

# Barentswatch live AIS
# AIS_CLIENT_ID=
# AIS_CLIENT_SECRET=

# IDUN remote inference (required for production without local GPU)
# Set IDUN_ENABLED=true on Hetzner VM; IDUN worker (school network) connects via WebSocket.
# Use Cloudflare Tunnel (cloudflared) or ngrok on the VM to expose the backend so IDUN can reach it.
# IDUN_ENABLED=true
# IDUN_API_KEY=your-secret-key-shared-with-idun-worker
# IDUN_FRAME_JPEG_QUALITY=80
# IDUN_TARGET_SEND_FPS=15

# Skip auto-starting default stream (e.g. when streams are started via API only)
# SKIP_DEFAULT_STREAM=false
