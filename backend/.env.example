# Required for local auth + backend API
DATABASE_URL=postgresql+psycopg://openar:openar_dev@localhost:5532/openar
JWT_SECRET_KEY=local-dev-jwt-secret-do-not-use-in-production
BETTER_AUTH_BASE_URL=http://localhost:3001
BETTER_AUTH_BASE_PATH=/api/auth

# Optional CORS tuning
CORS_ALLOW_PRIVATE_NETWORK_ORIGINS=false

# Production example:
# ENV=production
# NODE_ENV=production
# BETTER_AUTH_BASE_URL=https://ar.bridgable.ai

# Optional — S3 (endpoint/bucket/prefix derived from S3_PUBLIC_BASE_URL)
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/bridgable/openar/
# S3_PRESIGN_EXPIRES=900
# AIS_CLIENT_ID=
# AIS_CLIENT_SECRET=
