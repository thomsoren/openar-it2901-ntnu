# Required for local auth + backend API
DATABASE_URL=postgresql+psycopg://openar:openar_dev@localhost:5532/openar
JWT_SECRET_KEY=local-dev-jwt-secret-do-not-use-in-production
BETTER_AUTH_BASE_URL=http://localhost:3001
BETTER_AUTH_BASE_PATH=/api/auth

# Optional CORS tuning
CORS_ALLOW_PRIVATE_NETWORK_ORIGINS=false

# Production example:
# ENV=production
# NODE_ENV=production
# BETTER_AUTH_BASE_URL=https://ar.bridgable.ai

# FFmpeg encoder controls for RTSP publish
# ────────────────────────────────────────────────────────────────────
# Video codec selection — IMPORTANT for Mac users!
# Options:
#   - h264_videotoolbox: Apple Silicon/Intel hardware encoding (Mac only, RECOMMENDED)
#   - h264_nvenc: NVIDIA GPU hardware encoding (Linux/Windows with NVIDIA GPU)
#   - libx264: Software encoding (works everywhere, but CPU-intensive)
#   - auto: Tries h264_nvenc -> h264_videotoolbox -> libx264
#
# ⚠️  MAC USERS: Set FFMPEG_CODEC=h264_videotoolbox
# ⚠️  LINUX/WINDOWS with NVIDIA: Set FFMPEG_CODEC=h264_nvenc or auto
# ⚠️  If FFmpeg crashes with "Encoder not found", check this setting!
#
# FFMPEG_CODEC=h264_videotoolbox  # Uncomment for Mac
# FFMPEG_CODEC=auto               # Uncomment for Linux/Windows with NVIDIA

# Optional — S3 (endpoint/bucket/prefix derived from S3_PUBLIC_BASE_URL)
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BASE_URL=https://hel1.your-objectstorage.com/bridgable/openar/
# S3_PRESIGN_EXPIRES=900
# AIS_CLIENT_ID=
# AIS_CLIENT_SECRET=
