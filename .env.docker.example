# ── OpenAR Docker Configuration ──────────────────────────────────
# Copy to .env in the repo root: cp .env.docker.example .env

# GitHub Packages token (required for OpenBridge web components)
# Generate at: https://github.com/settings/tokens → read:packages scope
GITHUB_TOKEN=

# Auth secrets (change these in production)
BETTER_AUTH_SECRET=local-dev-auth-secret-do-not-use-in-production
JWT_SECRET_KEY=local-dev-jwt-secret-do-not-use-in-production

# PostgreSQL
POSTGRES_USER=openar
POSTGRES_PASSWORD=openar_dev
POSTGRES_DB=openar
# POSTGRES_PORT=5532

# Optional: override host-exposed ports
# REDIS_PORT=6379
# AUTH_PORT=3001
# FRONTEND_PORT=5273

# Optional: S3 storage
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BASE_URL=

# Optional: AIS vessel data
# AIS_CLIENT_ID=
# AIS_CLIENT_SECRET=
