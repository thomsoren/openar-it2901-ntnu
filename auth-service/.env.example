# Required for Better Auth service
BETTER_AUTH_SECRET=local-dev-auth-secret-do-not-use-in-production
DATABASE_URL=postgresql://openar:openar_dev@localhost:5532/openar
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_BASE_PATH=/api/auth

# Optional; defaults in code include localhost frontend ports
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Production examples:
# NODE_ENV=production
# BETTER_AUTH_URL=https://ar.bridgable.ai
# CORS_ORIGIN=https://ar.bridgable.ai
